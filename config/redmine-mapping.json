    "rules": [
      { "solution": "Expertis / Movilsat ERP", "weight": 0.80, "priority": 1, "keywords_any": ["expertis", "movilsat erp", "erp", "el programa", "el sistema"] },
      { "solution": "Movilsat", "weight": 0.05, "priority": 2, "keywords_any": ["movilsat", "app móvil", "app movil", "tablet", "smartphone", "parte movilsat"] },
      { "solution": "Sistemas", "weight": 0.05, "priority": 3, "keywords_any": ["servidor", "vpn", "red", "conexión", "conexion", "instalación", "instalacion", "equipo nuevo", "puesto"] },
      { "solution": "Portal OT", "weight": 0.02, "priority": 4, "keywords_any": ["portal ot", "portal de ot", "portal ordenes", "portal órdenes"] },
      { "solution": "App Fichajes / Gastos / Vacaciones", "weight": 0.02, "priority": 5, "keywords_any": ["fichajes", "fichar", "gastos", "vacaciones app", "app fichajes"] },
      { "solution": "Soluciones IA", "weight": 0.02, "priority": 6, "keywords_any": ["inteligencia artificial", "ia", "agente", "automatización ia", "automatizacion ia"] },
      { "solution": "Planificador Inteligente", "weight": 0.01, "priority": 7, "keywords_any": ["planificador inteligente", "planificador", "rutas", "optimización de rutas"] },
      { "solution": "Business Intelligence", "weight": 0.01, "priority": 8, "keywords_any": ["business intelligence", "bi", "cuadro de mando", "dashboard bi", "power bi"] },
      { "solution": "Comercial", "weight": 0.01, "priority": 9, "keywords_any": ["presupuesto cobertec", "contratar", "nueva licencia", "nuevo módulo", "precio cobertec"] },
      { "solution": "Resto", "weight": 0.01, "priority": 10, "keywords_any": [] }
    ],
    "default": "Expertis / Movilsat ERP"
  },

  "mapping_contract": {
    "description": "Contrato de salida del mapping. El clasificador semántico nunca debe enviar labels sin normalizar a Redmine.",
    "required_outputs": ["solution_associated", "block", "module", "need"],
    "optional_outputs": ["expertis_module"],
    "rules": [
      "Si la solución asociada es Expertis / Movilsat ERP, intentar resolver también expertis_module.",
      "Si la solución asociada no es Expertis / Movilsat ERP, expertis_module debe valer no_aplica.",
      "Los dominios semánticos no son valores finales válidos de Redmine; deben traducirse siempre a block/module/need.",
      "Aplicar normalization_aliases antes de cualquier validación estricta."
    ]
  },

